{
  "manifest_version": 3,
  "version": "1.0.0",
  "name": "Pip-Boy 3000",
  "description": "ROBCO Industries (TM) TermLink Protocol. A Fallout-inspired CRT phosphor theme for Chrome.",
  "theme": {
    "images": {
      "theme_frame": "images/theme_frame.png",
      "theme_toolbar": "images/theme_toolbar.png",
      "theme_ntp_background": "images/theme_ntp_background.png",
      "theme_tab_background": "images/theme_tab_background.png"
    },
    "colors": {
      "frame": [8, 18, 10],
      "frame_inactive": [6, 14, 8],
      "toolbar": [10, 22, 12],
      "tab_text": [160, 255, 160],
      "tab_background_text": [60, 140, 70],
      "bookmark_text": [130, 255, 140],
      "ntp_background": [5, 14, 7],
      "ntp_text": [140, 255, 150],
      "ntp_link": [190, 255, 190],
      "ntp_section": [10, 24, 12],
      "button_background": [12, 30, 16],
      "omnibox_background": [10, 24, 12],
      "omnibox_text": [150, 255, 160]
    },
    "tints": {
      "buttons": [0.33, 0.9, 0.55],
      "frame": [0.33, 1.0, 0.08],
      "background_tab": [0.33, 0.7, 0.15]
    },
    "properties": {
      "ntp_background_alignment": "center",
      "ntp_background_repeat": "no-repeat"
    }
  }
}
